---
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Moon from '../../components/Moon.svelte'
import { clickyMode } from '../../config'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.date.toLocaleDateString('sv-SE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---
<Layout title={post.data.title}>
  <main>
    <a class="back" href="/posts">
      <img src="/arrow.svg" alt="Till inlägg" />
    </a>

    <div class="content">
      <article class="reader-text">
        <h1>{post.data.title}</h1>
        <time class="date" datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <Content />
      </article>
    </div>

    <div class="stack">
      <div class="moon">
        <Moon clicky={clickyMode} client:load></Moon>
      </div>
      <div class="title">
        <a href="/">albertahnfelt.com</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
  }

  .content {
    display: flex;
    justify-content: center;
    padding: 3vh 1.5rem 0;
  }

  .back {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
  }

  .back img {
    display: block;
    width: 2rem;
    height: auto;
    transform: rotate(180deg);
  }

  .reader-text {
    width: 100%;
    max-width: 36rem; 
    margin-top: 6rem;
    margin-bottom: 8rem;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .reader-text :global(h1) {
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }

  .date {
    display: block;
    margin-bottom: 2rem;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .reader-text :global(h2) {
    font-size: 1.6rem;
    line-height: 1.3;
    margin: 2rem 0 1rem;
  }

  .reader-text :global(h3) {
    font-size: 1.3rem;
    margin: 1.6rem 0 0.8rem;
  }

  .reader-text :global(p) {
    margin-bottom: 1.2rem;
  }

  .reader-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .reader-text :global(a) {
    text-decoration: underline;
  }

  .reader-text :global(ul),
  .reader-text :global(ol) {
    margin: 0 0 1.2rem 1.4rem;
  }

  .reader-text :global(li) {
    margin-bottom: 0.4rem;
  }

  .reader-text :global(blockquote) {
    margin: 0 0 1.2rem;
    padding-left: 1rem;
    border-left: 0.2rem solid var(--white);
    font-style: italic;
  }

  .reader-text :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }

  .stack {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
  }

  .moon {
    position: absolute;
    top: 100%;
    left: 50%;
    margin-left: -4rem;
    margin-top: 0.5rem;
    width: 8rem;
    height: 8rem;
  }

  .title {
    font-size: 1.5rem;
    text-shadow: 0.12rem 0px 0px var(--black);
  }

  @media (max-width: 768px) {
    .content {
      padding: 2rem 1.5rem 12rem;
    }

    .reader-text {
      margin-top: 4rem;
      font-size: 1rem;
    }

    .stack {
      top: 1rem;
      right: 1rem;
    }

    .moon {
      width: 8rem;
      height: 8rem;
      margin-left: -4rem;
    }

    .title {
      font-size: 1.4rem;
    }
  }
</style>
