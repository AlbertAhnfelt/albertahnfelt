---
import { Picture } from 'astro:assets'
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Moon from '../../components/Moon.svelte'
import { clickyMode } from '../../config'
import tvBuilding from '../../assets/images/tv-building.jpg'
import outsideBookshelf from '../../assets/images/outside-bookshelf.jpg'

export async function getStaticPaths() {
  const posts = await getCollection('posts')
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)
---
<Layout title={post.data.title}>
  <main>
    <div class="content">
      <div class="left">
        <a class="back" href="/posts">
          <img src="/arrow.svg" alt="Till inlägg" />
        </a>

        <div class="photos">
          <Picture
            class="photo photo-top"
            src={tvBuilding}
            formats={['avif', 'webp']}
            widths={[400, 800]}
            sizes="(max-width: 600px) 60vw, 28vw"
            alt=""
            loading="eager"
          />

          <Picture
            class="photo photo-bottom"
            src={outsideBookshelf}
            formats={['avif', 'webp']}
            widths={[500, 1000]}
            sizes="(max-width: 600px) 75vw, 34vw"
            alt=""
            loading="eager"
          />
        </div>
      </div>

      <article class="reader-text">
        <h1>{post.data.title}</h1>
        <Content />
      </article>
    </div>

    <div class="stack">
      <div class="moon">
        <Moon clicky={clickyMode} client:load></Moon>
      </div>
      <div class="title">
        <a href="/">albertahnfelt.com</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
  }

  .content {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
    padding: 3vh 16rem 0 0;
  }

  .left {
    position: relative;
    flex: 0 0 auto;
  }

  .back {
    position: absolute;
    top: 0;
    right: 0;
  }

  .back img {
    display: block;
    width: 2rem;
    height: auto;
    transform: rotate(180deg);
  }

  .photos {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2vh;
  }

  .photo {
    display: block;
    width: auto;
    height: auto;
  }

  .photo-top {
    max-width: 22rem;
    max-height: 36vh;
  }

  .photo-bottom {
    max-width: 28rem;
    max-height: 49vh;
  }

  .reader-text {
    flex: 1;
    min-width: 0;
    margin-top: 6rem;
    margin-right: 3rem;
    margin-bottom: 8rem;
    font-size: 1.05rem;
    line-height: 1.6;

  }

  .reader-text :global(h1) {
    font-size: 2.2rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .reader-text :global(h2) {
    font-size: 1.6rem;
    line-height: 1.3;
    margin: 2rem 0 1rem;
  }

  .reader-text :global(h3) {
    font-size: 1.3rem;
    margin: 1.6rem 0 0.8rem;
  }

  .reader-text :global(p) {
    margin-bottom: 1.2rem;
  }

  .reader-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .reader-text :global(a) {
    text-decoration: underline;
  }

  .reader-text :global(ul),
  .reader-text :global(ol) {
    margin: 0 0 1.2rem 1.4rem;
  }

  .reader-text :global(li) {
    margin-bottom: 0.4rem;
  }

  .reader-text :global(blockquote) {
    margin: 0 0 1.2rem;
    padding-left: 1rem;
    border-left: 0.2rem solid var(--white);
    font-style: italic;
  }

  .reader-text :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }

  .stack {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
  }

  .moon {
    position: absolute;
    bottom: 100%;
    left: 50%;
    margin-left: -6rem;
    margin-bottom: 0.5rem;
    width: 12rem;
    height: 12rem;
  }

  .title {
    font-size: 2rem;
    text-shadow: 0.12rem 0px 0px var(--black);
  }

  @media (max-width: 768px) {
    .content {
      flex-direction: column;
      gap: 1.5rem;
      padding: 2rem 1.5rem 12rem;
    }

    .photo-top {
      max-width: 45vw;
      max-height: 30vh;
    }

    .photo-bottom {
      max-width: 52vw;
      max-height: 35vh;
    }

    .reader-text {
      margin-top: 0;
      font-size: 1rem;
    }

    .stack {
      bottom: 1rem;
      right: 1rem;
    }

    .moon {
      width: 8rem;
      height: 8rem;
      margin-left: -4rem;
    }

    .title {
      font-size: 1.4rem;
    }
  }
</style>
