---
import SidebarLayout from '../layouts/SidebarLayout.astro'
import { socials } from '../data/socials'
---
<SidebarLayout title="Om">
  <article class="reader-text">
    <p>Välkommen till albertahnfelt.com!</p>
    <p>Jag studerar vanligtvis till civilingenjör i industriell ekonomi vid Lunds Tekniska Högskola, och är intresserad av lite allt möjligt.</p>
    <p>Det här är min digitala lekstuga. Ta en titt runt!</p>

    <nav class="socials">
      {socials.map((social) => (
        <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.name}>
          <img src={social.icon} alt={social.name} />
        </a>
      ))}
    </nav>
  </article>
</SidebarLayout>

<style>
  .reader-text {
    max-width: 28rem;
    margin-top: 2rem;
    justify-self: center;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .reader-text {
      margin-top: 6rem;
    }
  }

  .reader-text p {
    margin-bottom: 1.2rem;
  }

  .reader-text p:last-child {
    margin-bottom: 0;
  }

  .socials {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 4rem;
  }

  .socials a {
    display: block;
    line-height: 0;
  }

  .socials img {
    width: 1.9rem;
    height: 1.9rem;
    object-fit: contain;
    filter: invert(1) drop-shadow(0.12rem 0 0 var(--black));
    transition: transform 0.15s ease, filter 0.15s ease;
  }

  .socials a:hover img,
  .socials a.clicky-hover img {
    filter: invert(1) drop-shadow(0 0 0 transparent);
    transform: scale(var(--hover-scale));
  }
</style>
